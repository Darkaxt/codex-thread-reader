<Window x:Class="CodexThreadReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Codex Thread Reader" Height="780" Width="1280" MinHeight="620" MinWidth="980"
        Loaded="Window_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Codex home" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" x:Name="CodexHomeTextBox" MinWidth="360" VerticalContentAlignment="Center" />
            <Button Grid.Column="2" x:Name="RefreshButton" Content="Refresh" Margin="8,0,0,0" Padding="14,6" Click="RefreshButton_Click" />
            <Button Grid.Column="3" x:Name="OpenExportsButton" Content="Open exports" Margin="8,0,0,0" Padding="14,6" Click="OpenExportsButton_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" x:Name="SearchTextBox" MinWidth="260" VerticalContentAlignment="Center" TextChanged="SearchTextBox_TextChanged" />
            <TextBlock Grid.Column="2" Text="Filter" VerticalAlignment="Center" Margin="12,0,8,0" />
            <ComboBox Grid.Column="3" x:Name="FilterComboBox" Width="140" SelectionChanged="FilterComboBox_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True" />
                <ComboBoxItem Content="Anchored" />
                <ComboBoxItem Content="Smoked" />
                <ComboBoxItem Content="Active" />
                <ComboBoxItem Content="Archived" />
            </ComboBox>
            <TextBox Grid.Column="4" x:Name="AnchorIdTextBox" MinWidth="260" Margin="12,0,0,0" VerticalContentAlignment="Center"
                     ToolTip="Paste a Codex thread ID to anchor it at the top." />
            <Button Grid.Column="5" x:Name="AnchorButton" Content="Anchor ID" Margin="8,0,0,0" Padding="14,6" Click="AnchorButton_Click" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.48*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.52*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="ThreadsGrid"
                      ItemsSource="{Binding}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      SelectionChanged="ThreadsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Pin" Binding="{Binding AnchorMark}" Width="42" />
                    <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedText}" Width="118" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                    <DataGridTextColumn Header="Project" Binding="{Binding Cwd}" Width="1.5*" />
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="86" />
                    <DataGridTextColumn Header="Flags" Binding="{Binding FlagsText}" Width="1.2*" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#D7DDE5" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#D7DDE5" BorderThickness="1" Padding="12" CornerRadius="6" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="DetailTitleTextBlock" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailMetaTextBlock" Foreground="#52606D" Margin="0,6,0,0" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailFlagsTextBlock" Foreground="#334E68" Margin="0,6,0,0" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="ExportButton" Content="Export selected" Padding="14,6" Click="ExportButton_Click" IsEnabled="False" />
                            <Button x:Name="RemoveAnchorButton" Content="Remove anchor" Margin="8,0,0,0" Padding="14,6" Click="RemoveAnchorButton_Click" IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="1" x:Name="PreviewStatusTextBlock" Foreground="#52606D" Margin="0,0,0,6" />
                <ListBox Grid.Row="2" x:Name="PreviewListBox" VirtualizingStackPanel.IsVirtualizing="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#D7DDE5" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Foreground="#102A43" />
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="3" x:Name="StatusTextBlock" Foreground="#52606D" Margin="0,8,0,0" TextWrapping="Wrap" />
    </Grid>
</Window>
