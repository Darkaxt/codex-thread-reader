<Window x:Class="CodexThreadReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodexThreadReader"
        mc:Ignorable="d"
        Title="Codex Thread Reader" Height="820" Width="1320" MinHeight="660" MinWidth="1060"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7F6F2" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E2DC" />
        <SolidColorBrush x:Key="TextBrush" Color="#202124" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6F6C66" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#8B8780" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#7C5C00" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ChatAssistantBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ChatUserBrush" Color="#F2EFE8" />
        <SolidColorBrush x:Key="ChatToolBrush" Color="#F6F6F6" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="326" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Codex" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="Thread Reader" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" />
                </Grid>

                <TextBox Grid.Row="1" x:Name="SearchTextBox" Margin="0,0,0,8"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged"
                         ToolTip="Search by title, thread ID, path, or recovery flag." />

                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="FilterComboBox" SelectionChanged="FilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="All" IsSelected="True" />
                        <ComboBoxItem Content="Anchored" />
                        <ComboBoxItem Content="Smoked" />
                        <ComboBoxItem Content="Active" />
                        <ComboBoxItem Content="Archived" />
                    </ComboBox>
                    <Button Grid.Column="1" x:Name="OpenExportsButton" Content="Exports" Margin="8,0,0,0" Click="OpenExportsButton_Click" />
                </Grid>

                <Grid Grid.Row="3" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Theme" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1" x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="System" Tag="System" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Projects" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,6" />
                    <TreeView Grid.Row="1" x:Name="ThreadsTree"
                              ItemsSource="{Binding}"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectedItemChanged="ThreadsTree_SelectedItemChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:SidebarGroupViewModel}" ItemsSource="{Binding Threads}">
                                <DockPanel Margin="0,8,0,4">
                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding CountText}" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="8,0,0,0" />
                                </DockPanel>
                            </HierarchicalDataTemplate>

                            <DataTemplate DataType="{x:Type local:ThreadRowViewModel}">
                                <Border Padding="9,7" Margin="0,1,0,1" CornerRadius="6" Background="Transparent">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AnchorMark}" Width="14" Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SidebarMeta}" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="{DynamicResource SubtleTextBrush}" Margin="0,3,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>

                <StackPanel Grid.Row="5" Margin="0,12,0,0">
                    <TextBlock Text="Anchor hidden thread" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,5" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="AnchorIdTextBox" VerticalContentAlignment="Center"
                                 ToolTip="Paste a Codex thread ID to anchor it at the top." />
                        <Button Grid.Column="1" x:Name="AnchorButton" Content="Anchor" Margin="8,0,0,0" Click="AnchorButton_Click" />
                    </Grid>
                    <TextBlock x:Name="StatusTextBlock" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource BorderBrush}" />

        <Grid Grid.Column="2" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,16" Background="{DynamicResource PanelBackgroundBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DetailTitleTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailMetaTextBlock" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                        <TextBlock x:Name="DetailFlagsTextBlock" FontSize="12" Foreground="{DynamicResource AccentTextBrush}" Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="18,0,0,0">
                        <Button x:Name="ExportButton" Content="Export" Click="ExportButton_Click" IsEnabled="False" />
                        <Button x:Name="RemoveAnchorButton" Content="Unanchor" Margin="8,0,0,0" Click="RemoveAnchorButton_Click" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" Padding="28,22" VerticalScrollBarVisibility="Auto" Background="{DynamicResource WindowBackgroundBrush}">
                <ItemsControl x:Name="ChatItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,18">
                                <Border MaxWidth="780"
                                        HorizontalAlignment="{Binding BubbleAlignment}"
                                        Background="{Binding BubbleBackground}"
                                        BorderBrush="{Binding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold" Foreground="{Binding HeaderBrush}" FontSize="12" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontFamily="{Binding FontFamily}" FontSize="13" Foreground="{Binding TextBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,12" Background="{DynamicResource PanelBackgroundBrush}">
                <TextBlock x:Name="PreviewStatusTextBlock" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
